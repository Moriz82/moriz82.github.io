<footer class="stats-strip">
  <a class="stat-card" href="{{footer.htbUrl}}" target="_blank" rel="noopener">
    <span class="c tl"></span><span class="c tr"></span><span class="c bl"></span><span class="c br"></span>
    <span class="stat-label">HTB</span>
    <span class="stat-value">{{footer.htbTotal}} OWNED</span>
  </a>
  <a class="stat-card" href="{{root}}about.html#ctfs">
    <span class="c tl"></span><span class="c tr"></span><span class="c bl"></span><span class="c br"></span>
    <span class="stat-label">CTFs</span>
    <span class="stat-value">{{footer.ctfCount}} PLAYED</span>
  </a>
  <a class="stat-card" href="https://github.com/Moriz82" target="_blank" rel="noopener">
    <span class="c tl"></span><span class="c tr"></span><span class="c bl"></span><span class="c br"></span>
    <span class="stat-label">GITHUB</span>
    <span class="stat-value">@moriz82</span>
  </a>
</footer>
<div class="colophon">
  <span>// {{year}} Will DeDominico · built on markdown</span>
  <span>{{footer.buildTime}}</span>
</div>
